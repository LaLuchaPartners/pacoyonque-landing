---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import fondoWeb from '../assets/hero/fondoweb.webp';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "Paco Yonque" } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/x-icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<ClientRouter />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&family=Playfair+Display:ital,wght@0,400..900;1,400..900&display=swap" rel="stylesheet">
	</head>
	<body>
		<img src={fondoWeb.src} alt="" class="bg-web" aria-hidden="true" />
		<main>
			<slot />
		</main>
		<script>
			document.addEventListener('astro:before-preparation', () => {
				if (!document.documentElement.dataset.direction) {
					document.documentElement.dataset.direction = 'forward';
				}
			});
			document.addEventListener('astro:after-swap', () => {
				delete document.documentElement.dataset.direction;
			});
		</script>
		<script>
			function forcePlayVideos() {
				document.querySelectorAll('video').forEach((video) => {
					video.muted = true;
					const promise = video.play();
					if (promise !== undefined) {
						promise.catch(() => {
							// Si el autoplay falla, intentar al primer toque del usuario
							const resume = () => {
								video.play();
								document.removeEventListener('touchstart', resume);
								document.removeEventListener('click', resume);
							};
							document.addEventListener('touchstart', resume, { once: true });
							document.addEventListener('click', resume, { once: true });
						});
					}
				});
			}

			// Al cargar la página
			document.addEventListener('DOMContentLoaded', forcePlayVideos);
			// Al navegar entre páginas con Astro transitions
			document.addEventListener('astro:page-load', forcePlayVideos);

			// Usar IntersectionObserver para reanudar videos al entrar al viewport
			const videoObserver = new IntersectionObserver((entries) => {
				entries.forEach((entry) => {
					const video = entry.target as HTMLVideoElement;
					if (entry.isIntersecting && video.paused) {
						video.play().catch(() => {});
					}
				});
			}, { threshold: 0.25 });

			function observeVideos() {
				document.querySelectorAll('video').forEach((v) => videoObserver.observe(v));
			}
			document.addEventListener('DOMContentLoaded', observeVideos);
			document.addEventListener('astro:page-load', observeVideos);
		</script>
	</body>
</html>

<style>
	main {
		width: 100%;
		overflow-x: hidden;
	}

	.bg-web {
		position: fixed;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center;
		z-index: -1;
	}
</style>
