---
import { Image } from 'astro:assets';
import fondo from '../../assets/reservas/fondoestrellas.webp';
import icono from '../../assets/reservas/iconoreservas.webp';
import iconoCalendario from '../../assets/reservas/calendarioicono.webp';
import iconoHorario from '../../assets/reservas/horarioicono.webp';
import iconoPersonas from '../../assets/reservas/personasicono.webp';
import iconoCompletado from '../../assets/reservas/reservacompletadaicono.webp';
import flechaInferior from '../../assets/reservas/flechainferior.webp';
---

<section id="reservas" class="reservas">
  <Image src={fondo} alt="" class="reservas__bg" aria-hidden="true" />

  <!-- Paso 1: Datos -->
  <div class="reservas__content" id="paso1">
    <Image src={icono} alt="Reservas" class="reservas__icon" />
    <h2 class="reservas__title">Reservas</h2>
    <p class="reservas__desc">
      Gracias por confiar en nosotros.<br />
      Estamos felices de ser parte de tus momentos mas especiales.
    </p>
    <div class="reservas__btns">
      <a href="https://api.whatsapp.com/send/?phone=51944586533&text&type=phone_number&app_absent=0&wame_ctl=1" target="_blank" rel="noopener noreferrer" class="reservas__btn">Reservas</a>
      <a href="https://api.whatsapp.com/send/?phone=51944586533&text&type=phone_number&app_absent=0&wame_ctl=1" target="_blank" rel="noopener noreferrer" class="reservas__btn">Reservas Corporativas</a>
      <a href="https://www.mesa247.pe/lima/restaurante/paco-yonque" target="_blank" rel="noopener noreferrer" class="reservas__btn">Mesa 24/7</a>
    </div>
  </div>

  <!-- Paso 2: Calendario -->
  <div class="reservas__content hidden" id="paso2">
    <Image src={iconoCalendario} alt="Calendario" class="reservas__icon" />

    <div class="cal">
      <div class="cal__nav">
        <button class="cal__arrow" id="prevMes">&#8249;</button>
        <div class="cal__mes-box">
          <span class="cal__mes" id="calMes">Enero</span>
        </div>
        <button class="cal__arrow" id="nextMes">&#8250;</button>
      </div>

      <div class="cal__grid">
        <span class="cal__dow">Mar</span>
        <span class="cal__dow">Mie</span>
        <span class="cal__dow">Jue</span>
        <span class="cal__dow">Vie</span>
        <span class="cal__dow">Sab</span>
        <span class="cal__dow">Dom</span>
      </div>
      <div class="cal__days" id="calDays"></div>
    </div>

    <button class="reservas__btn" id="btnPaso2">Continuar</button>
  </div>

  <!-- Paso 3: Horarios -->
  <div class="reservas__content hidden" id="paso3">
    <Image src={iconoHorario} alt="Horarios" class="reservas__icon" />

    <div class="hor__mes-box">
      <span class="hor__titulo">Horarios</span>
    </div>

    <div class="hor__grid" id="horGrid"></div>

    <button class="reservas__btn" id="btnPaso3">Continuar</button>
  </div>

  <!-- Paso 4: Personas y celebración -->
  <div class="reservas__content hidden" id="paso4">
    <Image src={iconoPersonas} alt="Personas" class="reservas__icon" />
    <div class="reservas__form">
      <input
        type="number"
        placeholder="Nº Personas:"
        class="reservas__input"
        min="1"
      />
      <textarea
        placeholder="¿Qué celebras?:"
        class="reservas__input reservas__textarea"
      ></textarea>
      <button class="reservas__btn" id="btnPaso4">Continuar</button>
    </div>
  </div>

  <!-- Paso 5: Confirmación -->
  <div class="reservas__content hidden" id="paso5">
    <p class="reservas__completado">¡Registro<br />completado!</p>
    <Image src={iconoCompletado} alt="Reserva completada" class="reservas__icon-completado" />
    <button class="reservas__chevron" id="btnPaso5">
      <Image src={flechaInferior} alt="Continuar" class="reservas__flecha" />
    </button>
  </div>
</section>

<style>
  .reservas {
    position: relative;
    width: 100%;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .reservas__bg {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 75%;
    height: auto;
    z-index: 0;
  }

  .reservas__content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    text-align: center;
    max-width: 780px;
    padding: 4rem 2rem;
  }

  .hidden { display: none !important; }

  @keyframes ticketWobble {
    0%   { transform: rotate(-18deg); }
    10%  { transform: rotate(-13deg); }
    22%  { transform: rotate(-23deg); }
    35%  { transform: rotate(-15deg); }
    48%  { transform: rotate(-21deg); }
    60%  { transform: rotate(-17deg); }
    72%  { transform: rotate(-19.5deg); }
    85%  { transform: rotate(-18deg); }
    100% { transform: rotate(-18deg); }
  }

  .reservas__icon {
    width: 90px;
    height: auto;
  }

  #paso1 .reservas__icon {
    transform-origin: 50% 50%;
    animation: ticketWobble 5s cubic-bezier(0.34, 1.56, 0.64, 1) infinite;
  }

  .reservas__title {
    font-family: 'Times New Roman', Times, serif;
    font-style: italic;
    font-weight: normal;
    color: #FEECCD;
    font-size: 2rem;
    line-height: 123.8%;
    letter-spacing: 0.1em;
    margin: 0;
  }

  .reservas__desc {
    font-family: 'Times New Roman', Times, serif;
    font-style: italic;
    color: #BAA694;
    font-size: 1.25rem;
    line-height: 123.8%;
    letter-spacing: 0.1em;
    margin: 0;
  }

  .reservas__form {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    width: 100%;
    margin-top: 0.5rem;
  }

  #paso1 .reservas__input {
    max-width: 300px;
  }

  #paso4 .reservas__form {
    gap: 1rem;
    align-items: center;
  }

  #paso4 .reservas__input {
    width: 360px;
    max-width: 90vw;
    padding: 0.8rem 1rem;
  }

  #paso4 .reservas__btn {
    margin-top: 1.5rem;
  }

  .reservas__input {
    width: 100%;
    max-width: 460px;
    padding: 0.35rem 1rem;
    background: #311D1D;
    color: #F9EAD0;
    font-family: 'Times New Roman', Times, serif;
    font-style: italic;
    font-size: 1.2rem;
    letter-spacing: 0.1em;
    border: none;
    border-radius: 20px;
    outline: none;
  }

  .reservas__textarea {
    height: 140px;
    resize: none;
    border-radius: 16px;
    padding-top: 0.6rem;
    line-height: 1.4;
  }

  .reservas__input::placeholder {
    color: #F9EAD0;
    opacity: 0.8;
  }

  .reservas__btns {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    width: 100%;
    margin-top: 0.5rem;
  }

  .reservas__btn {
    width: 100%;
    max-width: 300px;
    padding: 0.35rem 1rem;
    background: transparent;
    color: #D9B982;
    font-family: 'Times New Roman', Times, serif;
    font-style: italic;
    font-size: 1.2rem;
    letter-spacing: 0.1em;
    border: 1px solid #D9B982;
    border-radius: 20px;
    cursor: pointer;
    transition: background 0.3s ease;
  }

  .reservas__btn:hover {
    background: rgba(217, 185, 130, 0.1);
  }

  /* ── Reset fuente botones ── */
  .reservas button {
    font-family: 'Times New Roman', Times, serif;
    font-style: italic;
  }

  /* ── Calendario ── */
  .cal {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    width: 100%;
  }

  .cal__nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    width: 100%;
  }

  .cal__arrow {
    background: #311D1D;
    border: none;
    color: #F9EAD0;
    font-size: 1.8rem;
    cursor: pointer;
    line-height: 1;
    padding: 0.1rem 0.75rem;
    border-radius: 20px;
    font-family: 'Times New Roman', Times, serif;
    font-style: normal;
    opacity: 0.9;
    transition: opacity 0.2s;
  }

  .cal__arrow:hover { opacity: 1; }

  .cal__mes-box {
    background: #311D1D;
    border-radius: 20px;
    padding: 0.35rem 3rem;
    min-width: 220px;
  }

  .cal__mes {
    font-family: 'Times New Roman', Times, serif;
    font-style: italic;
    color: #F9EAD0;
    font-size: 1.2rem;
    letter-spacing: 0.1em;
  }

  .cal__grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 0.25rem 2.2rem;
    width: 100%;
    max-width: 480px;
  }

  .cal__dow {
    font-family: 'Times New Roman', Times, serif;
    font-style: italic;
    color: #F9EAD0;
    font-size: 0.9rem;
    letter-spacing: 0.05em;
    text-align: center;
  }

  .cal__days {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 1.2rem 2.2rem;
    width: 100%;
    max-width: 480px;
  }

  .cal__day {
    font-family: 'Times New Roman', Times, serif !important;
    font-style: italic !important;
    color: #F9EAD0;
    font-size: 1rem;
    letter-spacing: 0.05em;
    text-align: center;
    cursor: pointer;
    padding: 0.2rem;
    border-radius: 50%;
    transition: background 0.2s;
    background: none;
    border: none;
  }

  .cal__day:hover {
    background: rgba(249, 234, 208, 0.15);
  }

  .cal__day.selected {
    background: rgba(249, 234, 208, 0.25);
  }

  .cal__day.muted {
    opacity: 0.2;
    cursor: default;
  }

  .cal__day.muted:hover {
    background: none;
  }

  /* ── Confirmación ── */
  .reservas__completado {
    font-family: 'Times New Roman', Times, serif;
    font-style: italic;
    color: #D0B78C;
    font-size: 2rem;
    line-height: 123.8%;
    letter-spacing: 0.1em;
    text-align: center;
    margin: 0;
  }

  .reservas__icon-completado {
    width: 100px;
    height: auto;
    margin: 1.5rem 0;
  }

  .reservas__chevron {
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    opacity: 0.85;
    transition: opacity 0.2s;
  }

  .reservas__chevron:hover { opacity: 1; }

  .reservas__flecha {
    width: 28px;
    height: auto;
    display: block;
  }

  /* ── Horarios ── */
  .hor__mes-box {
    background: #311D1D;
    border-radius: 20px;
    padding: 0.35rem 3rem;
    min-width: 220px;
  }

  .hor__titulo {
    font-family: 'Times New Roman', Times, serif;
    font-style: italic;
    color: #F9EAD0;
    font-size: 1.2rem;
    letter-spacing: 0.1em;
  }

  .hor__grid {
    display: grid;
    grid-template-columns: repeat(6, auto);
    gap: 1.1rem 1.5rem;
    justify-content: center;
    width: 100%;
    max-width: 800px;
    margin: 1.5rem 0;
  }

  @media (max-width: 768px) {
    .reservas__bg {
      width: 120%;
    }

    .reservas__content {
      padding: 3rem 1.25rem;
      max-width: 100%;
    }

    .reservas__icon {
      width: 65px;
    }

    .reservas__title {
      font-size: 1.2rem;
    }

    .reservas__desc {
      font-size: 0.8rem;
      max-width: 240px;
    }

    /* Paso 1 inputs */
    #paso1 .reservas__input {
      max-width: 65vw;
      width: 65vw;
      font-size: 0.9rem;
      padding: 0.65rem 1rem;
    }

    /* Paso 2: calendario */
    .cal__mes-box {
      min-width: 160px;
      padding: 0.35rem 1.5rem;
    }

    .cal__grid {
      gap: 0.25rem 1rem;
      max-width: 320px;
    }

    .cal__days {
      gap: 0.9rem 1rem;
      max-width: 320px;
    }

    /* Paso 3: horarios 3 columnas */
    .hor__grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 0.75rem 0.5rem;
      max-width: 100%;
      padding: 0 0.5rem;
    }

    .hor__grid button {
      width: 100% !important;
      white-space: nowrap;
      font-size: 0.85rem !important;
      padding: 0.3rem 0.25rem !important;
    }

    .hor__mes-box {
      min-width: 160px;
      padding: 0.35rem 1.5rem;
    }

    /* Paso 4 inputs */
    #paso4 .reservas__input {
      width: 65vw;
      max-width: 65vw;
      font-size: 0.9rem;
      padding: 0.5rem 1rem;
    }

    #paso4 .reservas__textarea {
      height: 100px;
    }

    /* Botón continuar */
    .reservas__btn {
      max-width: 75vw;
      font-size: 1rem;
    }
  }
</style>

<script>
</script>
