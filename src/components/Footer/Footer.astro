---
import { Image } from 'astro:assets';
import iconoFacturacion from '../../assets/footer/facturacionicono.webp';
import iconoLibro from '../../assets/footer/libroicono.webp';
---

<footer id="footer" class="footer">

  <div class="footer__links">
    <a href="https://comprobantes.lalucha.com.pe/" target="_blank" rel="noopener noreferrer" class="footer__link">
      <Image src={iconoFacturacion} alt="Facturación Electrónica" class="footer__icon" />
      <span class="footer__link-text">FACTURACIÓN ELECTRÓNICA</span>
    </a>
    <a href="https://reclamos.lalucha.com.pe/" target="_blank" rel="noopener noreferrer" class="footer__link">
      <Image src={iconoLibro} alt="Libro de Reclamaciones" class="footer__icon" />
      <span class="footer__link-text">LIBRO DE RECLAMACIONES</span>
    </a>
  </div>

  <div class="footer__divider"></div>

  <div class="footer__bottom">
    <span class="footer__copy">Todos los derechos reservados por Lucha Partners SAC - Copyright © 2026</span>
    <div class="footer__legal">
      <a href="#" class="footer__legal-link">Términos y condiciones</a>
      <a href="#" class="footer__legal-link">Política de privacidad</a>
    </div>
  </div>

</footer>

<style>
  .footer {
    width: 100%;
    padding: 0 3.5rem 3rem;
    margin-top: -2rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  /* ── Links superiores ── */
  .footer__links {
    display: flex;
    justify-content: center;
    gap: 20rem;
    align-items: center;
  }

  .footer__link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
    color: #D0B78C;
    transition: opacity 0.2s;
  }

  .footer__link:hover { opacity: 0.75; }

  .footer__icon {
    width: 58px;
    height: auto;
  }

  .footer__link-text {
    font-family: 'Times New Roman', Times, serif;
    font-style: normal;
    color: #D0B78C;
    font-size: 1rem;
    letter-spacing: 0.15em;
  }

  /* ── Divider ── */
  .footer__divider {
    width: 100%;
    height: 1px;
    background: #D0B78C;
    opacity: 0.4;
  }

  /* ── Bottom ── */
  .footer__bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .footer__copy {
    font-family: 'Times New Roman', Times, serif;
    font-style: italic;
    color: #D0B78C;
    font-size: 0.78rem;
    letter-spacing: 0.05em;
  }

  .footer__legal {
    display: flex;
    gap: 1.5rem;
  }

  .footer__legal-link {
    font-family: 'Times New Roman', Times, serif;
    font-style: italic;
    color: #D0B78C;
    font-size: 0.78rem;
    letter-spacing: 0.05em;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .footer__legal-link:hover { opacity: 0.75; }

  @media (max-width: 768px) {
    .footer {
      padding: 0 2rem 2.5rem;
      margin-top: 0;
      gap: 1rem;
    }

    .footer__links {
      gap: 3rem;
    }

    .footer__link {
      flex-direction: column;
      align-items: center;
      gap: 0.5rem;
      text-align: center;
    }

    .footer__icon {
      width: 32px;
    }

    .footer__link-text {
      font-size: 0.55rem;
      letter-spacing: 0.06em;
    }

    .footer__bottom {
      flex-direction: column-reverse;
      align-items: center;
      gap: 0.4rem;
      text-align: center;
    }

    .footer__legal {
      gap: 1rem;
    }

    .footer__copy {
      font-size: 0.55rem;
    }

    .footer__legal-link {
      font-size: 0.65rem;
    }
  }
</style>
