---
import { Image } from 'astro:assets';
import imgServicio from '../../assets/equipo/imagenservicio.webp';
import imgCocina from '../../assets/equipo/imagencocina.webp';
---

<section id="equipo" class="equipo">
  <div class="equipo__inner">

    <div class="equipo__header">
      <h2 class="equipo__title">Nuestro Equipo</h2>
      <p class="equipo__desc">
        Somos un restaurante ideal para celebrar los más memorables momentos junto a tus seres queridos.
      </p>
    </div>

    <div class="equipo__grid">
      <div class="equipo__card">
        <Image src={imgServicio} alt="Equipo de Servicio" class="equipo__img" />
        <span class="equipo__caption">Servicio</span>
      </div>
      <div class="equipo__card">
        <Image src={imgCocina} alt="Equipo de Cocina" class="equipo__img" />
        <span class="equipo__caption">Cocina</span>
      </div>
    </div>

  </div>
</section>

<style>
  .equipo {
    width: 100%;
    min-height: 100vh;
    display: flex;
    align-items: center;
    margin-top: 4rem;
  }

  .equipo__inner {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 4rem 3.5rem;
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  /* ── Header ── */
  .equipo__header {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .equipo__title {
    font-family: 'Times New Roman', Times, serif;
    font-style: italic;
    font-weight: normal;
    color: #D0B78C;
    font-size: 1.4em;
    line-height: 123.8%;
    letter-spacing: 0.1em;
    margin: 0;
  }

  .equipo__desc {
    font-family: 'Times New Roman', Times, serif;
    font-style: italic;
    color: #CD9968;
    font-size: 1rem;
    line-height: 123.8%;
    letter-spacing: 0.1em;
    margin: 0;
    max-width: 550px;
  }

  /* ── Grid de imágenes ── */
  .equipo__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }

  .equipo__card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .equipo__img {
    width: 100%;
    height: auto;
    border-radius: 8px;
    display: block;
  }

  .equipo__caption {
    font-family: 'Times New Roman', Times, serif;
    font-style: italic;
    color: #CD9968;
    font-size: 1.1rem;
    letter-spacing: 0.1em;
  }

  @media (max-width: 768px) {
    .equipo {
      margin-top: 3rem;
      min-height: auto;
    }

    .equipo__inner {
      padding: 3.5rem 1.5rem;
      gap: 2rem;
    }

    .equipo__header {
      padding: 3rem 2rem 0;
    }

    .equipo__title {
      font-size: 1.2rem;
    }

    .equipo__desc {
      font-size: 0.85rem;
      margin-top: 0.2rem;
    }

    .equipo__grid {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .equipo__caption {
      font-size: 0.85rem;
    }

    .equipo__img {
      width: 90%;
      margin: 0 auto;
    }

    .equipo__card {
      gap: 0.3rem;
    }
  }
</style>
