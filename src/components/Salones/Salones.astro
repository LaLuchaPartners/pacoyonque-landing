---
import videoSrc from '../../assets/salones/privados-web 02.mp4';
---

<section id="salones" class="salones">
  <div class="salones__inner">

    <h2 class="salones__title">Salones Privados</h2>

    <p class="salones__desc">
      Disfruta de una experiencia exclusiva con mayordomo personal y vista hacia<br />
      el Parque Kennedy. El espacio ideal para celebrar momentos especiales.
    </p>

    <div class="salones__cols">
      <div class="salones__col">
        <p class="salones__col-nombre">Salón Escritor</p>
        <p class="salones__col-num" data-target="8">0</p>
        <p class="salones__col-label">personas</p>
      </div>
      <div class="salones__divider"></div>
      <div class="salones__col">
        <p class="salones__col-nombre">Gran Salón del Mapa</p>
        <p class="salones__col-num" data-target="20">0</p>
        <p class="salones__col-label">personas</p>
      </div>
      <div class="salones__divider"></div>
      <div class="salones__col">
        <p class="salones__col-nombre">Salón del Cazador</p>
        <p class="salones__col-num" data-target="10">0</p>
        <p class="salones__col-label">personas</p>
      </div>
    </div>

    <video
      class="salones__video"
      src={videoSrc}
      autoplay
      muted
      loop
      playsinline
      width="1156"
      height="620"
    ></video>

  </div>
</section>

<style>
  .salones {
    width: 100%;
    min-height: 100vh;
    display: flex;
    align-items: center;
    margin-top: 4rem;
  }

  .salones__inner {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 4rem 3.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
  }

  .salones__title {
    font-family: 'Times New Roman', Times, serif;
    font-style: italic;
    font-weight: normal;
    color: #D0B78C;
    font-size: 2rem;
    line-height: 123.8%;
    letter-spacing: 0.1em;
    margin: 0;
    text-align: center;
  }

  .salones__desc {
    font-family: 'Times New Roman', Times, serif;
    font-style: italic;
    color: #CD9968;
    font-size: 1rem;
    line-height: 123.8%;
    letter-spacing: 0.1em;
    text-align: center;
    margin: 0;
  }

  /* ── Columnas ── */
  .salones__cols {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    width: 100%;
    max-width: 700px;
  }

  .salones__col {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    padding: 0 2rem;
  }

  .salones__divider {
    width: 1px;
    height: 80px;
    background: #D0B78C;
    opacity: 0.6;
  }

  .salones__col-nombre {
    font-family: 'Times New Roman', Times, serif;
    font-style: italic;
    color: #D0B78C;
    font-size: 0.95rem;
    letter-spacing: 0.1em;
    margin: 0;
    text-align: center;
  }

  .salones__col-num {
    font-family: 'Times New Roman', Times, serif;
    font-style: italic;
    color: #CD9968;
    font-size: 2.5rem;
    letter-spacing: 0.05em;
    margin: 0;
    line-height: 1.1;
  }

  .salones__col-label {
    font-family: 'Times New Roman', Times, serif;
    font-style: italic;
    color: #CD9968;
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    margin: 0;
  }

  /* ── Video ── */
  .salones__video {
    width: 860px;
    height: 460px;
    max-width: 100%;
    display: block;
    object-fit: cover;
  }

  @media (max-width: 768px) {
    .salones {
      margin-top: 2rem;
      min-height: auto;
    }

    .salones__inner {
      padding: 3rem 1.5rem 0;
      gap: 1.5rem;
    }

    .salones__title {
      font-size: 1.3rem;
    }

    .salones__desc {
      font-size: 0.8rem;
      max-width: 100%;
    }

    .salones__desc br {
      display: none;
    }

    .salones__cols {
      max-width: 100%;
    }

    .salones__col {
      padding: 0 0.75rem;
    }

    .salones__col-nombre {
      font-size: 0.7rem;
    }

    .salones__col:nth-child(1) .salones__col-nombre {
      max-width: 3.5rem;
    }

    .salones__col:nth-child(3) .salones__col-nombre {
      max-width: 5rem;
    }

    .salones__col-num {
      font-size: 1.8rem;
    }

    .salones__col-label {
      font-size: 0.65rem;
    }

    .salones__divider {
      height: 60px;
    }

    .salones__video {
      width: 100%;
      height: 480px;
      max-width: none;
      margin: 0 -1.5rem;
      width: calc(100% + 3rem);
    }
  }
</style>

<script>
  function initCounters() {
    const nums = document.querySelectorAll<HTMLElement>('.salones__col-num[data-target]');

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        const el = entry.target as HTMLElement;
        const target = parseInt(el.dataset.target ?? '0', 10);
        const duration = 1200;
        const start = performance.now();

        function tick(now: number) {
          const progress = Math.min((now - start) / duration, 1);
          const ease = 1 - Math.pow(1 - progress, 3);
          el.textContent = String(Math.round(ease * target));
          if (progress < 1) requestAnimationFrame(tick);
        }

        requestAnimationFrame(tick);
        observer.unobserve(el);
      });
    }, { threshold: 0.5 });

    nums.forEach((el) => observer.observe(el));
  }

  document.addEventListener('DOMContentLoaded', initCounters);
  document.addEventListener('astro:page-load', initCounters);
</script>
